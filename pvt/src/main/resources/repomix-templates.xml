<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
  <meta charset="UTF-8">
  <title>Tạo tài khoản</title>
  <link rel="stylesheet" href="/css/mdb.min.css">
</head>
<body>

<h2 style="text-align:center">Tạo tài khoản</h2>

<div th:if="${message}" style="color: green; text-align:center">
